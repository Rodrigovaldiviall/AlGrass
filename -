CREATE OR REPLACE FUNCTION "public"."protect_locked_game_fields"() RETURNS "trigger"
    LANGUAGE "plpgsql"
    AS $$
declare
  confirmed_count integer;
begin

  -- solo validar OLD en updates
  if tg_op = 'UPDATE' then

    select count(*)
    into confirmed_count
    from game_players gp
    where gp.game_id = new.id
      and gp.status = 'confirmed';

    if confirmed_count > 0 then

      if new.total_spots is distinct from old.total_spots
         or new.format is distinct from old.format
         or new.price_per_person is distinct from old.price_per_person then

        raise exception
        'cannot modify format/spots/pricing after confirmed players exist';

      end if;

    end if;

  end if;

  -- calcular SOLO para matches
  if new.type = 'match' or new.type is null then
    new.price_total :=
      coalesce(new.price_per_person, 0)
      * coalesce(new.total_spots, 0);
  end if;

  return new;
end;
$$;


ALTER FUNCTION "public"."protect_locked_game_fields"() OWNER TO "postgres";


CREATE OR REPLACE FUNCTION "public"."required_players_from_format"("p_format" "text") RETURNS integer
    LANGUAGE "plpgsql" IMMUTABLE
    AS $$
declare
  v_players integer;
begin
  v_players := split_part(lower(p_format), 'v', 1)::integer;
  return v_players * 2;
exception
  when others then
    return 0;
end;
$$;


